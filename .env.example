TELEGRAM_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# Daily processing schedule (local Mac time, 24h format)
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# Gemini feature flag (optional, default: false = use Claude)
USE_GEMINI=false
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
